package templates

import "time"

type AgentRowData struct {
	ID        int64
	Name      string
	Masked    string
	CreatedAt time.Time
	UpdatedAt time.Time
}

type AgentListPageData struct {
	Agents       []AgentRowData
	CSRFToken    string
	NewToken     string
	NewAgentName string
	// MCPEndpoint is the absolute URL clients POST to (scheme://host/mcp).
	// Computed server-side from the request so the displayed snippet matches
	// the host the operator actually browsed to.
	MCPEndpoint string
}

templ AgentListPage(data AgentListPageData) {
	@BaseLayout(BaseLayoutData{Title: "Agents", CSRFToken: data.CSRFToken, ActivePage: "agents"}) {
		@PageHeader("SN—AGT", T(ctx, "agents.agents"), T(ctx, "agents.agents_subtitle"))
		if data.NewToken != "" {
			<div class="alert alert-success" style="word-break: break-all;">
				<strong>{ data.NewAgentName }</strong> : { T(ctx, "agents.token_created") }
				@TokenRevealBox("create-token", data.NewToken)
				<small style="display: block; margin-top: 0.5rem; opacity: 0.85;">{ T(ctx, "agents.token_warning") }</small>
			</div>
		}
		@CardPlain() {
			<table class="table">
				<thead>
					<tr>
						<th>{ T(ctx, "agents.name") }</th>
						<th>{ T(ctx, "agents.token") }</th>
						<th>{ T(ctx, "agents.created") }</th>
						<th>{ T(ctx, "agents.actions") }</th>
					</tr>
				</thead>
				<tbody>
					for _, a := range data.Agents {
						<tr>
							<td>
								<a href={ templ.SafeURL("/admin/agents/" + int64ToString(a.ID)) } class="link">{ a.Name }</a>
							</td>
							<td><code>{ a.Masked }</code></td>
							<td class="font-mono text-xs">{ FormatDateTime(a.CreatedAt) }</td>
							<td>
								<div class="flex flex-wrap gap-2">
									<a href={ templ.SafeURL("/admin/agents/" + int64ToString(a.ID)) } class="button button-secondary">{ T(ctx, "agents.permissions") }</a>
									<form method="POST" action={ templ.SafeURL("/admin/agents/" + int64ToString(a.ID) + "/delete") } class="inline">
										<input type="hidden" name="csrf_token" value={ data.CSRFToken }/>
										<button type="submit" class="button button-danger">{ T(ctx, "common.delete") }</button>
									</form>
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
		<div class="mt-4 plugin-settings-grid">
			@mcpConnectCard(data.MCPEndpoint)
			@Card(T(ctx, "agents.create_agent")) {
				<form method="POST" action="/admin/agents">
					<input type="hidden" name="csrf_token" value={ data.CSRFToken }/>
					<div class="form-group">
						<label for="agent_name">{ T(ctx, "agents.name") }</label>
						<input type="text" id="agent_name" name="name" required class="form-input" placeholder="Claude Code"/>
					</div>
					<button type="submit" class="button button-primary">{ T(ctx, "agents.create_agent") }</button>
				</form>
			}
		</div>
	}
}

// mcpConnectCard renders a one-liner registration command for Claude Code.
// The endpoint is computed server-side so the URL matches the host the
// operator is currently browsing.
templ mcpConnectCard(endpoint string) {
	<div>
		@Card("MCP endpoint") {
			<p class="text-sm" style="margin: 0 0 0.75rem 0; opacity: 0.85;">
				Connect any MCP client. Example for Claude Code CLI. Swap the placeholder token with one of the agent tokens above.
			</p>
			<pre style="margin: 0 0 0.5rem 0; padding: 0.75rem; background: rgba(0,0,0,0.2); border-radius: 4px; overflow-x: auto;"><code>{ mcpAddCommand(endpoint) }</code></pre>
			<small style="display: block; margin-bottom: 0.75rem; opacity: 0.75;">
				Restart Claude Code if it's already running: MCP servers should load at startup.
			</small>
			<div class="form-group">
				<label>Quick check (curl)</label>
				<pre style="margin: 0; padding: 0.75rem; background: rgba(0,0,0,0.2); border-radius: 4px; overflow-x: auto;"><code>{ mcpCurlSnippet(endpoint) }</code></pre>
			</div>
		}
	</div>
}
